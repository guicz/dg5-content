rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function dg5User() {
      return request.auth != null
        && request.auth.token.email.matches('.*@dg5\\.com\\.br$');
    }

    match /clients/{clientId}/{allPaths=**} {
      allow read: if dg5User();
      allow write: if dg5User()
        && request.resource.size < 25 * 1024 * 1024
        && request.resource.contentType.matches(
          'image/.*|application/pdf|application/vnd.*|text/.*'
        );
    }
  }
}
